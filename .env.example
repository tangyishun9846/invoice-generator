# 商业发票生成器 — 配置示例
# 复制为 .env, 改成你公司的真实信息. 部署到 Render/Railway/Fly 时在平台后台设置环境变量即可.

# ============== 卖方 (你的公司) 信息 ==============
# 显示在发票的 "From:" 区块

SELLER_NAME=YOUR COMPANY NAME CO.,LTD

# 地址行用 | 分隔, 顺序就是显示顺序
SELLER_ADDRESS_LINES=ROOM 101, BUILDING A,|123 SAMPLE STREET, DISTRICT,|CITY, COUNTRY

# 用来在 PI 文本里定位"发货人段结束"的锚点 — 通常是你地址的最后一行
# 收货人块就紧跟在这个锚点之后
SELLER_ANCHOR=CITY, COUNTRY


# ============== 业务默认值 ==============
# 解析失败或字段缺失时的兜底值. 留空就显示空.

DEFAULT_INVOICE_NO=INV-001
DEFAULT_GOODS_NAME=YOUR GOODS NAME
DEFAULT_GOODS_BRAND=(YOUR BRAND)
DEFAULT_HS_CODE=0000.0000
DEFAULT_PORT_LOADING=
DEFAULT_PORT_DISCHARGE=
DEFAULT_DISCHARGE_COUNTRY=

# PI 文本里识别"货物名"的正则 (Python re 语法)
# 改成匹配你的货物, 例: 硫化钠 (允许 YELLOW/RED 等可选修饰词):
#   (SODIUM\s+SULPHIDE(?:\s+[A-Z]+)?\s+FLAKES[^\n]*)
GOODS_NAME_PATTERN=([A-Z][A-Z\s]+(?:POWDER|FLAKES|GRANULES|LIQUID)[^\n]*)


# ============== CLI 模式 (auto_invoice.py) 印章路径 ==============
# 只在跑命令行版本时用到; Web 版印章通过浏览器上传

# SIGNATURE_PATH=/absolute/path/to/your_signature.png
# SEAL_PATH=/absolute/path/to/your_company_seal.png


# ============== Web 部署相关 ==============

# 平台一般会自动注入 PORT, 本地默认 5001
# PORT=8080

# Chrome 路径 (容器里通常是 /usr/bin/google-chrome-stable, Dockerfile 已自动设置)
# CHROME_BIN=/usr/bin/google-chrome-stable

# 当以 root 运行 Chrome 时需要 --no-sandbox; Docker 里自动判断, 一般无需手动设置
# CHROME_NO_SANDBOX=1
